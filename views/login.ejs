<html>
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title>Mavis</title>
        <meta name="description" content="">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="css/main.css">
        <link rel="stylesheet" href="css/login.css">
    </head>
    <body>
        <div class="container">
            <div class="Object Login">
                <div class="objectHeader">
                <h1>Log in</h1>
                </div>
                <form action="/login" method="POST" novalidate>

                    <div class="input-group">
                        <label for="email">Email address</label>
                        <input type="email" id="email" name="email" placeholder="name@example.com" required autocomplete="email">
                    </div>

                    <div class="input-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password" placeholder="••••••••" required>
                    </div>

                    <button type="submit" class="login-btn buttonSmall green"><p>Log in</p></button>
                </form>

                <p class="register-redirect">
                    Don't have an Account? <a href="/register">Register</a>
                </p>
                
            </div>
        </div>

        <script src="/js/validator.js"></script>
    </body>
</html>