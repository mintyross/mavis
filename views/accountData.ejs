<!-- 
    Сторінка оновлення даних профілю
-->
<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title>Mavis - Update Profile</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="css/main.css">
        <link rel="stylesheet" href="css/login.css">
        <link rel="stylesheet" href="css/mobile.css">
        <link rel="icon" type="image/x-icon" href="/images/mavis-icon.png">
        <style>
            :root {
                /* Passes the background path cleanly into your CSS memory grid */
                /* Drops back to the default bird wallpaper if no custom file exists */
                --user-bg-image: url('<%- user.background ? user.background : "/images/mavis-background.jpg" %>');
            }
        </style>
    </head>
    <body data-theme="<%- user.siteTheme %>">
        <div class="container">
            <div class="Object Login">
                <div class="objectHeader">
                    <h1>Change Profile Data</h1>
                </div>

                <form id="accountDataForm" method="post" enctype="multipart/form-data" novalidate>

                    <div class="input-group">
                        <label for="userName">Full Name</label>
                        <input type="text" id="userName" name="userName" placeholder="John Doe" value="<%- user.userName %>" required autocomplete="name">
                    </div>

                    <div class="input-group">
                        <label for="email">Email address</label>
                        <input type="email" id="email" name="email" placeholder="name@example.com" value="<%- user.email %>" required autocomplete="email">
                    </div>

                    <div class="input-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password" placeholder="••••••••" required>
                    </div>

                    <div class="input-group">
                        <label for="passwordConfirm">Confirm Password</label>
                        <input type="password" id="passwordConfirm" name="passwordConfirm" placeholder="••••••••" required>
                    </div>

                    <!-- Поле для завантаження аватара -->
                    <div class="input-group file-group">
                        <label for="avatar">Avatar Image</label>
                        <input type="file" id="avatar" name="avatar" accept="image/*" required>
                    </div>
                    <div><button type="submit" class="login-btn buttonSmall green"><p>Apply changes</p></button></div>
                    <p class="register-redirect">

                        <a href="/accountDelete" class="delete-account-link" onclick="return confirm('You`re about to delete this profile. The action cannot be undone. Do you wish to proceed?');" style="color: rgba(184, 25, 41, 0.8);">
                        Delete Account
                        </a>
                        
                        <a href="/">Go back</a>
                    </p>
                    
                </form>
            </div>
        </div>
    </body>
</html>
