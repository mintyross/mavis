<!-- 
    Сторінка мапи пристроїв.
    
    Містить навігаційне меню та віджет, у якому можна додати, видалити та редагувати кімнати будинків та їхні пристрої.
    Елемент canvas відображає девайси, що знаходяться у обраній кімнаті обраного будинку. 
    Логіка canvas міститься за адресою /js/canvas.js.
-->
<!DOCTYPE html>
<!--[if lt IE 7]>      <html class="no-js lt-ie9 lt-ie8 lt-ie7"> <![endif]-->
<!--[if IE 7]>         <html class="no-js lt-ie9 lt-ie8"> <![endif]-->
<!--[if IE 8]>         <html class="no-js lt-ie9"> <![endif]-->
<!--[if gt IE 8]>      <html class="no-js"> <!--<![endif]-->
<html>
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title>Mavis - Device Map</title>
        <meta name="description" content="">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="css/main.css">
        <link rel="stylesheet" href="css/mobile.css">
        <link rel="stylesheet" href="css/devicemap.css">
    </head>
    <body data-theme="<%- user.siteTheme %>">
        <div class="container">

            <%- include('partials/navbar') %>

            <!-- Основний елемент сторіни -->
            <div class="objectArea">
                <div class="Object Plate">
                    <div class="objectOptions">
                        <div class="buttonSmall roomPicker" style="background-color: <%- locals.activeRoom ? activeRoom.roomColor + '80' : '#ffa600' %>;"> <p><%- locals.activeRoom && activeRoom.roomId ? activeRoom.roomName : 'Rooms' %> </p></div>
                        <div class="buttonSmall addRoom" style="align-content: center;"><p>Devices</p></div>
                    </div>
                    <div class="mapCanvas">
                        <canvas id="canvas"></canvas>
                    </div>
                </div>
            </div> 

            <!-- Дії з кімнатами -->
            <div class="roomWindowArea" style="display: none;">
                <div class="housePickerWindow Object Large" id="roomPickerWindow">
                    <div class="objectHeader"><p>Manage rooms</p></div>
                    <div class="optionArea">
                        <% if (locals.rooms && rooms.length > 0) { %>
                            <% rooms.forEach(function(room) { 
                                // Перевіряємо, чи є будинок активним у сесії
                                const currentActiveRoomId = locals.activeRoom ? activeRoom.roomId : null;
                                const isIdMatch = (currentActiveRoomId && currentActiveRoomId == room.roomId);
                                const isPrimary = isIdMatch ? 'Primary' : '';
                            %>
                                <!-- Додаємо клас houseItemButton та data-id, що передає дані до скрипта-->
                                <div class="Button houseItemButton <%- isPrimary %> " id="houseItemButton" style="background-color: <%- room.roomColor ? room.roomColor + '80' : '#ffa60080' %>;"
                                    data-house-id="<%- room.houseId %>"
                                    data-room-id="<%- room.roomId %>" 
                                    data-room-name="<%- room.roomName %>" 
                                    data-room-color="<%- room.roomColor || '#ffa600' %>">
                                    <p><%- room.roomName %></p>
                                    
                                    <!-- Кнопка з трьома крапками -->
                                    <div class="buttonSmall optionsButton" id="optionsButton">
                                        <img src="/images/dots.png" alt="Options">
                                        
                                        <!-- Випадаюче меню дій (приховане за замовчуванням) -->
                                        <div class="dropdownActions">
                                            <div class="dropdownItem roomEditButton"><p>Edit</p></div>
                                            <div class="dropdownItem removeRoomButton"><p>Remove</p></div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p style="text-align:center; padding: 20px; opacity:0.6;">No rooms linked to this house yet.</p>
                        <% } %>

                        <div class="buttonContainer">
                            <div class="buttonSmall" id="roomPickerAdd"><p>Add a room</p></div>
                            <div class="buttonSmall Primary" id="roomPickerOKButton" style="backdrop-filter: unset;"><p>Close</p></div>
                        </div>
                    </div>
                </div>  

                <!-- Додати кімнату -->
                <link rel="stylesheet" href="css/login.css">
                <div class="Login housePickerWindow addHouse Object Large" id="roomAddWindow" style="margin: 10% auto; display: none">
                    <div class="objectHeader"><p>Add a room</p></div>

                    <form id="addRoomForm" action="/addRoomForm" method="post" novalidate>

                        <input type="hidden" id="addRoomHouseIdInput" name="houseId" value="<%- locals.activeHouseId || '' %>">

                        <div class="input-group">
                            <label for="roomName">Room Name</label>
                            <input type="text" id="roomName" name="roomName" placeholder="Living room" required>
                        </div>
                        
                        <div class="input-group">
                            <label for="roomColor">Select room color:</label>
                            <input type="color" id="roomColor" name="roomColor" value="#ffa600">
                        </div>
                        

                        <div class="buttonContainer bc-fix">
                            <div class="buttonSmall Secondary" id="roomAddWindowCancelButton"><p>Cancel</p></div>
                            <button type="submit" class="buttonSmall green" id="houseAddWindowAddButton"><p>Add</p></button>
                        </div>
                    </form>
                </div> 

                <!-- Змінити кімнату -->
                <div class="Login housePickerWindow addHouse Object Large" id="roomEditWindow" style="margin: 10% auto; display: none">
                    <div class="objectHeader"><p>Edit the room</p></div>

                    <form id="editRoomForm" action="/editRoomForm" method="post" novalidate>
                        <input type="hidden" id="editRoomIdInput" name="roomId" value="">
                        <input type="hidden" id="editHouseIdInput" name="houseId" value="">

                        <div class="input-group">
                            <label for="editRoomName">Room Name</label>
                            <input type="text" id="editRoomName" name="roomName" placeholder="Living room" required>
                        </div>
                        
                        <div class="input-group">
                            <label for="editRoomColor">Select room color:</label>
                            <input type="color" id="editRoomColor" name="roomColor" value="#ffa600">
                        </div>

                        <div class="buttonContainer bc-fix">
                            <div class="buttonSmall Secondary" id="roomEditWindowCancelButton"><p>Cancel</p></div>
                            <button type="submit" class="buttonSmall green" id="roomEditWindowEditButton"><p>Edit</p></button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Дії з пристроями-->
            <div class="deviceWindowArea">
                <div class="housePickerWindow Object Large" id="devicePickerWindow" style="display: none;">
                    <div class="objectHeader"><p>Manage devices</p></div>
                    <div class="optionArea">
                        <% if (locals.devices && devices.length > 0) { %>
                            <% devices.forEach(function(device) { %>
                                <!-- Картка пристрою із відображенням типу його з'єднання -->
                                <div class="Button houseItemButton" data-device-id="<%- device.deviceId %>">
                                    <p><%- device.deviceName %> <span style="font-size: 0.8em; opacity: 0.6;"><%- device.usageScheme %> </span></p>
                                    <div id="optionsButton" class="buttonSmall optionsButton">
                                        <img src="/images/dots.png" alt="Options">
                                        <div class="dropdownActions">
                                            <div class="dropdownItem removeDeviceButton"><p>Remove</p></div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p style="text-align:center; padding: 20px; opacity:0.6;">No devices linked to this room yet.</p>
                        <% } %>

                        <div class="buttonContainer">
                            <div class="buttonSmall" id="devicePickerAdd"><p>Add a Device</p></div>
                            <div class="buttonSmall Primary" id="devicePickerOKButton" style="backdrop-filter: unset;"><p>Close</p></div>
                        </div>
                    </div>
                </div>  

                <!-- ВІКНО СТВОРЕННЯ НОВОГО ПРИСТРОЮ -->
                <div class="Login housePickerWindow addHouse Object Large" id="deviceAddWindow" style="margin: 10% auto; display: none">
                    <div class="objectHeader"><p>Add a device</p></div>

                    <form id="addDeviceForm" action="/addDeviceForm" method="post" novalidate>
                        <div class="input-group">
                            <label for="deviceName">Device Name</label>
                            <input type="text" id="deviceName" name="deviceName" placeholder="Smart Lamp, Motion Sensor..." required>
                        </div>
                        
                        <div class="input-group">
                            <label for="usageScheme">Device Usage Scheme</label>
                            <select id="usageScheme" name="usageScheme">
                                <option value="on/off">On/Off Switchable (Lights, Relays, Smart Plugs)</option>
                                <option value="sensor">Sensor Trigger (Motion, Temperature, Contact)</option>
                                <option value="dimmer">Analog Dimmer (Brightness, Fan Speed Control)</option>
                            </select>
                        </div>

                        <div class="buttonContainer bc-fix">
                            <div class="buttonSmall Secondary" id="deviceAddWindowCancelButton"><p>Cancel</p></div>
                            <button type="submit" class="buttonSmall green" id="deviceAddSubmitButton"><p>Add</p></button>
                        </div>
                    </form>
                </div>

            </div>
            

        </div>



        <!-- JQuery -->
        <script src="/js/jquery-4.0.0.min.js"></script> 

        <!-- Скрипт бере дані з сервера для використання на сторінці -->
        <script>
            const serverDevices = <%- JSON.stringify(devices || []) %>;
            const serverConnections = <%- JSON.stringify(connections || []) %>;
            console.log("Data successfully loaded into browser:", serverDevices);
        </script>

        <!-- Скрипт, що управляє елементом canvas -->
        <script src="/js/canvas.js"></script>

        <!-- Скрипт, що містить логіку сторінки (дії кнопок, відправка форм, стилі елементів) -->
        <script src="/js/devicemap.js"></script>
    </body>
</html>