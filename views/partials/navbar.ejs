<script src="/js/jquery-4.0.0.min.js"></script>
<div class="Header">
    <div class="Object Button Account">
        <!-- Клікабельна шапка акаунта -->
        <div class="accountHeader">
            <img src="<%- user.avatar %>" alt="Avatar">
            <p><%= user.userName %> </p>
        </div>
        
        <!-- Дропдаун, який початково прихований -->
        <div style="display: none;" id="accountDropdown">
            <a href="/accountData"><div class="Button"><p>change profile data</p></div></a>
            <div class="Button red" id="logoutButton"><p>Log out</p></div>
            <!-- Кнопка закриття (лінія/хрестик) -->
            <a id="accountDropdownClose" style="height: max-content;"><div class="textDevider"></div></a>
        </div>
    </div>
</div>


<div class="leftSide">
    <div class="leftNavBar">
        <nav>
            <div class="Mavis"><h1>MAVIS</h1></div>
            <a id="housePicker">
                <div class="Logo">
                    <div class="logoImage">
                        <img src="images/smart-home.png" alt="smart-home">
                    </div>
                    <div class="logoTextContainer">
                        <h2>My crib</h2>
                        <div class="textDevider"></div>
                        <h3>Peremohy st., 125-b</h3>
                    </div>
                </div>
            </a>

            <a href="/">
                <div class="leftNavButton <%= activePage == 'index' ? 'Primary' : '' %>">
                    <img src="images/menu-button.png" alt="Main page">
                    <p>Main page</p>
                </div>
            </a>

            <a href="/devicemap">
                <div class="leftNavButton <%= activePage == 'devicemap' ? 'Primary' : '' %>">
                    <img src="images/scheme.png" alt="Device map">
                    <p>Device map</p>
                </div>
            </a>

            <a href="/statistics">
                <div class="leftNavButton <%= activePage == 'statistics' ? 'Primary' : '' %>">
                    <img src="images/chart.png" alt="Statistics">
                    <p>Statistics</p>
                </div>
            </a>

            <a href="/settings">
                <div class="leftNavButton <%= activePage == 'settings' ? 'Primary' : 'Secondary' %> SettingsHotFix">
                    <img src="images/setting.png" alt="Settings">
                    <p>Settings</p>
                </div>
            </a>
        </nav>
    </div>
</div>
<div class="windowArea" style="display: none;">
    <div class="housePickerWindow Object Large">
        <div class="objectHeader"><p>Manage houses</p></div>
        <div class="optionArea">
            
            <div class="buttonContainer">
                <div class="buttonSmall Primary" id="housePickerAdd"><p>Add a house</p></div>
                <div class="buttonSmall Primary" id="housePickerOKButton"><p>Finish picking</p></div>
            </div>
        </div>

    </div>  
</div>

<script src="/js/navbar.js"></script>
<script>
    $(document).ready(function() {
        $("#housePicker").click(function(e) {
            e.preventDefault();
            $(".windowArea").css("display", "flex");
        });

        $("#housePickerOKButton").click(function(e) {
            e.preventDefault();
            $(".windowArea").css("display", "none");
        });
  
        // 1. ВІДКРИТТЯ: Клікам ТІЛЬКИ на шапку акаунта
        $(".accountHeader").click(function(e) {
            e.preventDefault();
            e.stopPropagation();
            $("#accountDropdown").fadeIn(200); 
        });

        // 2. ДОЗВІЛ НА КЛІК: Якщо клікнули на саме посилання, дозволяємо йому працювати
        $("#accountDropdown a").click(function(e) {
            e.stopPropagation(); // Не даємо події піднятися до батьківських елементів
            
            // Перестраховка: якщо браузер все одно блокує перехід, робимо його примусово через JS
            var url = $(this).attr("href");
            if (url) {
                window.location.href = url;
            }
            return true; 
        });

        // 3. ЗАКРИТТЯ: Клік на кнопку закриття
        $("#accountDropdownClose").click(function(e) {
            e.preventDefault();
            e.stopPropagation();
            $("#accountDropdown").fadeOut(200); 
        });

        // 4. ЗАКРИТТЯ ПО КЛІКУ ПОВЗ МЕНЮ: Клік у будь-якій іншій точці екрана
        $(document).click(function(e) {
            if (!$(e.target).closest('.Account').length) {
                $("#accountDropdown").fadeOut(200);
            }
        });





        $("#logoutButton").click(function(e) {
            e.preventDefault();
            
            // Відправляємо POST запит на сервер без перезавантаження сторінки
            $.post('/logout', function() {
                // Коли сервер успішно видалив сесію, перенаправляємо браузер на логін
                window.location.href = '/login';
            });
        });

    });
</script>