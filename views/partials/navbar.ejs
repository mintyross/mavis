<!-- 
    Partial-файл навігаційного меню.
    Містить саме навігаційне меню, меню дій з будинками, додавання та редагування будинку   
-->
<link rel="icon" type="image/x-icon" href="/images/mavis-icon.png">
<style>
    :root {
        /* Passes the background path cleanly into your CSS memory grid */
        /* Drops back to the default bird wallpaper if no custom file exists */
        --user-bg-image: url('<%- user.background ? user.background : "/images/mavis-background.jpg" %>');
    }
</style>

<script src="/js/jquery-4.0.0.min.js"></script>
<div class="Header">
    <div class="Object Button Account">
        <!-- Клікабельна шапка акаунта -->
        <div class="accountHeader">
            <img src="<%- user.avatar %>" alt="Avatar">
            <p><%= user.userName %> </p>
        </div>
        
        <!-- Дропдаун, який початково прихований -->
        <div style="display: none;" id="accountDropdown">
            <a href="/accountData"><div class="Button"><p>change profile data</p></div></a>
            <div class="Button red" id="logoutButton"><p>Log out</p></div>
            <!-- Кнопка закриття (лінія/хрестик) -->
            <a id="accountDropdownClose" style="height: max-content;"><div class="textDevider"></div></a>
        </div>
    </div>
</div>

<!-- Навігаційне меню -->
<div class="leftSide">
    <div class="leftNavBar">
        <nav>
            <div class="Mavis"><h1>MAVIS</h1></div>
            <a id="housePicker">
                <div class="Logo" >
                    <div class="logoImage">
                        <img src="images/smart-home.png" alt="smart-home">
                    </div>

                    <div class="logoTextContainer">
                        <% if (activeHouse) { %>
                            <!-- Виводимо дані вибраного будинку -->
                            <h3><%- activeHouse.houseName || activeHouse.housename %></h3>
                            <div class="textDevider"></div>
                            <p><%- activeHouse.houseLocation || activeHouse.houselocation %></p>
                        <% } else { %>
                            <!-- Заглушка, якщо будинків взагалі немає в базі -->
                            <h2>No House Selected</h2>
                            <div class="textDevider"></div>
                            <h3>Click to add or select</h3>
                        <% } %>
                    </div>
                    
                    
                </div>
            </a>

            <a href="/">
                <div class="leftNavButton <%= activePage == 'index' ? 'Primary' : '' %>">
                    <img src="images/menu-button.png" alt="Main page">
                    <p>Main page</p>
                </div>
            </a>

            <a href="/devicemap">
                <div class="leftNavButton <%= activePage == 'devicemap' ? 'Primary' : '' %>">
                    <img src="images/scheme.png" alt="Device map">
                    <p>Device map</p>
                </div>
            </a>

            <a href="/statistics">
                <div class="leftNavButton <%= activePage == 'statistics' ? 'Primary' : '' %>">
                    <img src="images/chart.png" alt="Statistics">
                    <p>Statistics</p>
                </div>
            </a>

            <a href="/settings">
                <div class="leftNavButton <%= activePage == 'settings' ? 'Primary' : 'Secondary' %> SettingsHotFix">
                    <img src="images/setting.png" alt="Settings">
                    <p>Settings</p>
                </div>
            </a>
        </nav>
    </div>
</div>

<!-- Меню дій з будниками -->
<div class="windowArea" id="housePickerWindowArea" style="display: none;">
    <div class="housePickerWindow Object Large" id="housePickerWindow">
        <div class="objectHeader"><p>Manage houses</p></div>
        <div class="optionArea">
            <% if (locals.houses && houses.length > 0) { %>
                <% houses.forEach(function(house) { 
                    // Перевіряємо, чи є будинок активним у сесії
                    const isIdMatch = (typeof activeHouseId !== 'undefined' && activeHouseId == (house.houseId));
                    const isPrimary = isIdMatch ? 'Primary' : '';
                %>
                    <!-- Додаємо клас houseItemButton та data-id -->
                    <div class="Button houseItemButton <%- isPrimary %>" data-id="<%- house.houseId %>">
                        <p><%- house.houseName %> at <%- house.houseLocation %></p>
                        
                        <!-- Кнопка з трьома крапками -->
                        <div class="buttonSmall optionsButton" id="optionsButton">
                            <img src="/images/dots.png" alt="Options">
                            
                            <!-- Випадаюче меню дій (приховане за замовчуванням) -->
                            <div class="dropdownActions">
                                <div class="dropdownItem houseEditButton" id=""><p>Edit</p></div>
                                <div class="dropdownItem removeHouseButton"><p>Remove</p></div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; padding: 20px; opacity:0.6;">No houses linked to this account yet.</p>
            <% } %>

            <div class="buttonContainer" id="addHouseButtonContainer">
                <div class="buttonSmall" id="housePickerAdd"><p>Add houses</p></div>
                <div class="buttonSmall Primary" id="housePickerOKButton" style="backdrop-filter: unset;"><p>Close</p></div>
            </div>
        </div>


    </div>  

    <!-- Меню додавання будинку -->
    <link rel="stylesheet" href="css/login.css">
    <div class="Login housePickerWindow addHouse Object Large" id="houseAddWindow" style="margin: 10% auto; display: none">
        <div class="objectHeader"><p>Add a house</p></div>

        <form id="addHouseForm" action="/addHouseForm" method="post" novalidate>
            <div class="input-group">
                <label for="houseName">House Name</label>
                <input type="text" id="houseName" name="houseName" placeholder="My crib" required>
            </div>

            <div class="input-group">
                <label for="houseLocation">House Location</label>
                <input type="text" id="houseLocation" name="houseLocation" placeholder="21st street" required>
            </div>

            <div class="objectArea buttonContainer bc-fix" style="padding: 0; margin: 20px">
                <div class="buttonSmall Secondary" id="houseAddWindowCancelButton"><p>Cancel</p></div>
                <button type="submit" class="buttonSmall green" id="houseAddWindowAddButton"><p>Add</p></button>
            </div>
        </form>


    </div> 

    <!-- Меню редагування будинку -->
    <div class="Login housePickerWindow addHouse Object Large" id="houseEditWindow" style="margin: 10% auto; display: none">
        <div class="objectHeader"><p>Edit the house</p></div>

        <form id="addHouseForm" action="/editHouseForm" method="post" novalidate>
            <input type="hidden" id="editHouseIdInput" name="houseId" value="">
            <div class="input-group">
                <label for="houseName">House Name</label>
                <input type="text" id="editHouseNameInput" name="houseName" placeholder="My crib" required>
            </div>

            <div class="input-group">
                <label for="houseLocation">House Location</label>
                <input type="text" id="editHouseLocationInput" name="houseLocation" placeholder="21st street" required>
            </div>

            <div class="objectArea buttonContainer bc-fix" style="padding: 0; margin: 20px">
                <div class="buttonSmall Secondary" id="houseEditWindowCancelButton"><p>Cancel</p></div>
                <button type="submit" class="buttonSmall green" id="houseEditWindowEditButton"><p>Edit</p></button>
            </div>
        </form>


    </div> 
</div>

<script src="/js/navbar.js"></script>